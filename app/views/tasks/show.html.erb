<div class = "task-container" ><h2><%= @task.title %></h2>
<p><%= @task.details %></p>
<p><% if @task.completed %>
  <p>✅ This task is completed</p>
<% else %>
  <p>⏳ This task is not completed yet</p>
<% end %></p>
<%= link_to "Delete",
  task_path(@task), class: "btn btn-primary"
  data: {turbo_method: :delete, turbo_confirm: "Are you sure?"}
%>
<%= link_to "Edit this task", edit_task_path(@task), class: "btn btn-primary" %>
</div>
